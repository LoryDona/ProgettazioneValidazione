pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat clean build'
                }
            }
        }

        stage('Test') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat test'
                }
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts artifacts: 'esameProgValid/build/libs/*.jar'
            }
        }
    }
}