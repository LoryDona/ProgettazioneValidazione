pipeline {
    agent any

    environment {
        JAVA_HOME = 'C:\\Program Files\\Eclipse Adoptium\\jdk-21.0.8.9-hotspot'
        PATH = "${JAVA_HOME}\\bin;${env.PATH}"
    }
    stages {

        stage('Clone Repo') {
            steps {
                checkout scm
            }
        }

        stage('Config Check') {
            steps {
                dir('esameProgValid') {
                    bat 'java -version'
                    bat 'gradlew.bat --version'
                }
            }
        }

        stage('Build') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat clean build -x test'
                }
            }
        }

        stage('Unit Test') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat test'
                }
            }
            post {
                always {
                    junit 'esameProgValid/build/test-results/test/*.xml'
                }
            }
        }

        stage('Coverage') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat jacocoTestReport'
                }
            }
        }

        stage('Publish Artifact') {
            steps {
                archiveArtifacts artifacts: 'esameProgValid/build/libs/*.jar', fingerprint: true
            }
        }
    }
}