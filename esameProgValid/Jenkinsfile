pipeline {
    agent any

    stages {
        stage('Clone Repo') {
            steps {
                checkout scm
            }
        }

        stage('Config Check') {
            steps {
                bat 'java -version'
                bat 'gradlew --version'
            }
        }

        stage('Build') {
            steps {
                bat 'gradlew clean assemble'
            }
        }

        stage('Unit Test') {
            steps {
                bat 'gradlew test'
            }
            post {
                always {
                    junit 'build/test-results/test/*.xml'
                }
            }
        }

        stage('System Test') {
            steps {
                bat 'gradlew systemTest'
            }
            post {
                always {
                    junit 'build/test-results/systemTest/*.xml'
                }
            }
        }

        stage('Coverage') {
            steps {
                bat 'gradlew jacocoTestReport'
            }
        }

        stage('Publish Artifact') {
            steps {
                archiveArtifacts artifacts: 'build/libs/*.jar', fingerprint: true
            }
        }
    }
}