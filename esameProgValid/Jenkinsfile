pipeline {
    agent any

    stages {

        stage('Clone Repo') {
            steps {
                checkout scm
            }
        }

        stage('Config Check') {
            steps {
                dir('esameProgValid') {
                    bat 'java -version'
                    bat 'gradlew.bat --version'
                }
            }
        }

        stage('Build') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat clean build -x test'
                }
            }
        }

        stage('Unit Test') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat test'
                }
            }
            post {
                always {
                    junit 'esameProgValid/build/test-results/test/*.xml'
                }
            }
        }

        stage('System Test') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat systemTest'
                }
            }
            post {
                always {
                    junit 'esameProgValid/build/test-results/systemTest/*.xml'
                }
            }
        }

        stage('Coverage') {
            steps {
                dir('esameProgValid') {
                    bat 'gradlew.bat jacocoTestReport'
                }
            }
        }

        stage('Publish Artifact') {
            steps {
                archiveArtifacts artifacts: 'esameProgValid/build/libs/*.jar', fingerprint: true
            }
        }
    }
}